# ---------------------------------------------------------------------------
# Backend selection
# ---------------------------------------------------------------------------
# stub   -> fully offline, deterministic; zero credentials (DEFAULT)
# gemini -> direct Gemini API via GOOGLE_API_KEY (no Vertex)
# vertex -> Vertex AI / Gemini Enterprise Agent Platform (needs project + auth)
EVAL_BACKEND=stub

# Model used by the agent's reasoning loop and by LLM-judges (when backend != stub)
AGENT_MODEL=gemini-2.5-flash
# Judge model for Layer-2 autoraters and Layer-3 custom judges (when backend != stub)
JUDGE_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Direct Gemini API (EVAL_BACKEND=gemini)
# ---------------------------------------------------------------------------
# GOOGLE_API_KEY=your-aistudio-key
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# ---------------------------------------------------------------------------
# Vertex / Gemini Enterprise Agent Platform (EVAL_BACKEND=vertex)
# ---------------------------------------------------------------------------
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# Staging bucket for Agent Engine deploys + AutoSxS pipelines
# STAGING_BUCKET=gs://your-staging-bucket
# Vertex AI Experiment name evaluations are logged under
# VERTEX_EXPERIMENT=card-benefits-eval

# ---------------------------------------------------------------------------
# Gating posture (see evals/gating/thresholds.yaml -> mode)
# full          -> LLM-judge + deterministic + custom judges (DEFAULT)
# deterministic -> only computation + tool-call + trajectory metrics (no LLM judge)
# ---------------------------------------------------------------------------
GATE_MODE=full
